using System;
using System.Collections.Generic;
using System.Text;

namespace upGrad_Week4_Day2
{
    internal class Method_Overloading
    {
        static void Main(string[] args)
        {
            Console.WriteLine("Addition of 2 integers: " + add(5, 10));
            Console.WriteLine("Addition of 3 integers: " + add(5, 10, 15));
            Console.WriteLine("Addition of 2 doubles: " + add(5.5, 10.5));
            Console.WriteLine("Addition of 3 doubles: " + add(5.5, 10.5, 15.5));
        }
        public static int add(int a, int b)
        {
            return (a+b);
        }

        public static int add(int a, int b, int c)
        {
            return (a + b + c);
        }
        public static double add(double a, double b)
        {
            return (a + b);
        }
        public static double add(double a, double b, double c)
        {
            return (a + b + c);
        }
    }
}
